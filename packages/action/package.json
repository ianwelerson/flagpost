{
  "name": "@flagpost/action",
  "version": "0.0.0",
  "private": true,
  "description": "GitHub Action that validates flag YAML and builds flags.json for a flagpost repo",
  "license": "MIT",
  "author": "Ian Welerson",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ianwelerson/flagpost.git",
    "directory": "packages/action"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "ncc build src/index.ts -o dist --source-map --license licenses.txt",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/exec": "^1.1.1",
    "@flagpost/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "@vercel/ncc": "^0.38.2",
    "@vitest/coverage-v8": "^2.1.4",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
