{
  "name": "@flagpost/sdk-js",
  "version": "0.1.0-alpha.1",
  "description": "JS SDK for reading feature flags from a flagpost repo",
  "license": "MIT",
  "author": "Ian Welerson",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ianwelerson/flagpost.git",
    "directory": "packages/sdk-js"
  },
  "homepage": "https://github.com/ianwelerson/flagpost/tree/main/packages/sdk-js",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@flagpost/core": "workspace:*"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.4",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
