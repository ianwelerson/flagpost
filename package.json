{
  "name": "flagpost",
  "version": "0.0.0",
  "private": true,
  "description": "Git-based feature flag control",
  "license": "MIT",
  "author": "Ian Welerson",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ianwelerson/flagpost.git"
  },
  "homepage": "https://github.com/ianwelerson/flagpost",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.27.9",
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "overrides": {
      "undici": ">=6.24.0"
    }
  }
}
